{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Lumos Backend (FastAPI)",
      "runtimeExecutable": "venv/bin/uvicorn",
      "runtimeArgs": ["backend.main:app", "--reload", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "Lumos Frontend (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 5173
    }
  ]
}
