# ─────────────────────────────────────────────
#  Lumos — Environment Variables Template
#  Copy this file to .env and fill in values.
#  NEVER commit .env to git!
# ─────────────────────────────────────────────

# AI Provider: gemini (free tier) or anthropic
AI_PROVIDER=gemini

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (free tier — https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...
# Optional extra keys from separate Google accounts — each adds an independent
# free-tier quota pool (model-major failover; production answer is a paid tier)
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# TCMB EVDS (free — evds3.tcmb.gov.tr -> Benim Sayfam -> Profilim -> API Anahtarı)
TCMB_EVDS_API_KEY=

# Clerk Auth
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev

# Database
DATABASE_URL=sqlite+aiosqlite:///./lumos.db
# For production:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/lumos

# Exchange Rate (optional)
EXCHANGE_RATE_API_KEY=

# App
APP_ENV=development
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
